{
  "name": "@ralphkrauss/agent-orchestrator",
  "version": "0.1.3",
  "description": "MCP agent orchestrator for Codex and Claude worker runs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "agent-orchestrator": "dist/cli.js",
    "agent-orchestrator-daemon": "dist/daemonCli.js",
    "agent-orchestrator-opencode": "dist/opencodeCli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/__tests__/*.test.js dist/__tests__/integration/*.test.js",
    "audit:prod": "pnpm audit --prod",
    "verify": "pnpm build && pnpm test && node scripts/check-publish-ready.mjs && node scripts/resolve-publish-tag.mjs >/dev/null && pnpm audit --prod && npm pack --dry-run",
    "prepack": "pnpm build",
    "pack:dry-run": "npm pack --dry-run"
  },
  "files": [
    "dist/",
    "src/",
    "!dist/__tests__/",
    "!src/__tests__/",
    "README.md",
    "PUBLISHING.md",
    "LICENSE.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ralphkrauss/agent-orchestrator.git"
  },
  "bugs": {
    "url": "https://github.com/ralphkrauss/agent-orchestrator/issues"
  },
  "homepage": "https://github.com/ralphkrauss/agent-orchestrator#readme",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ulid": "^2.4.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@cursor/sdk": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "path-to-regexp": ">=8.4.0"
  },
  "pnpm": {
    "overrides": {
      "tar": "^7.5.11",
      "undici": "^6.24.0",
      "@tootallnate/once": "^3.0.1"
    }
  },
  "packageManager": "pnpm@10.30.3"
}
